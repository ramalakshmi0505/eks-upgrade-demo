# Copy to terraform.tfvars and fill in your values.

region       = "eu-central-1"
cluster_name = "upgrade-demo"

# Start here, then bump to 1.33 in a pull request to demo the upgrade.
kubernetes_version = "1.32"

# Plug in an existing VPC and its private subnets.
vpc_id     = "vpc-xxxxxxxxxxxxxxxxx"
subnet_ids = ["subnet-aaaaaaaa", "subnet-bbbbbbbb", "subnet-cccccccc"]

node_instance_types = ["t3.large"]
node_min_size       = 2
node_max_size       = 5
node_desired_size   = 2
